{
  "name": "@asosunoff/ts-tools",
  "version": "1.1.6",
  "description": "TS-TOOLS",
  "homepage": "https://asosunoff.github.io/ts-tools/",
  "author": {
    "name": "Alexander Sosunov",
    "url": "https://github.com/aSosunoff"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bugs": {
    "url": "https://github.com/aSosunoff/ts-tools/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git://github.com/aSosunoff/ts-tools.git"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.60.1",
    "@typescript-eslint/parser": "^8.60.1",
    "eslint": "^10.4.1",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "prepublishOnly": "npm run build",
    "pack_local": "npm run build && npm pack",
    "pack_npm": "npm version patch && npm run prepublishOnly && npm publish"
  },
  "keywords": [
    "typescript",
    "types",
    "type-utils",
    "utility-types"
  ],
  "files": [
    "/dist",
    "/src",
    "ts-tools-pro-1-generics.svg",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  }
}
